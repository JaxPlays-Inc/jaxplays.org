{{- $events := slice -}}
{{- range where .Site.Pages "Type" "productions" -}}
  {{- $title := .Title -}}
  {{- $theatre := .Params.theatre -}}
  {{- $title := print $theatre " - " $title -}}
  {{- $featuredImage := .Params.featured_image -}}
  {{- $url := .RelPermalink -}}
  
  {{- /* Initialize default color */ -}}
  {{- $color := "#000" -}}
  
  {{- /* Try to fetch the theatre's color */ -}}
  {{- $theatreURL := $theatre | replaceRE "&" "and" | urlize | replaceRE "\\." "" -}}
  {{- with $.Site.GetPage "page" (printf "/theatres/%s" $theatreURL) -}}
    {{- $color = .Params.color | default "#000" -}}
  {{- end -}}

  {{- with .Params.showtimes -}}
    {{- if gt (len .) 0 -}}
      {{- /* Only take the first showtime */ -}}
      {{- $firstShowtime := index . 0 -}}
      {{- $firstShowtimeDateTime := $firstShowtime -}}
      {{- $firstShowtimeVenue := "" -}}
      {{- if in (printf "%T" $firstShowtime) "map" -}}
        {{- $firstShowtimeDateTime = index $firstShowtime "datetime" -}}
        {{- $firstShowtimeVenue = index $firstShowtime "venue" | default "" -}}
      {{- end -}}
      {{- $event := dict "title" $title "start" $firstShowtimeDateTime "theatre" $theatre "url" $url "color" $color "featured_image" $featuredImage -}}
      {{- with $firstShowtimeVenue -}}
        {{- $event = merge $event (dict "venue" .) -}}
      {{- end -}}
      {{- $events = $events | append $event -}}
    {{- end -}}
  {{- end -}}
{{- end -}}
{{- $events | jsonify -}}
